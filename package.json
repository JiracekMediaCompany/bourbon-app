{
  "name": "bourbon-app",
  "version": "1.0.0",
  "description": "Monorepo for Bourbon mobile and web applications",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "install-all": "npm install"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
